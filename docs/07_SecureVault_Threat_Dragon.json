                  "title": "Traffic interception without TLS",
                  "status": "Open",
                  "severity": "High",
                  "type": "Information Disclosure",
                  "description": "When deployed without HTTPS termination, credentials and tokens may traverse the network in clear text.",
                  "mitigation": "Terminate TLS at gateway or ingress in production.",
                  "modelType": "STRIDE"
                }
              ]
