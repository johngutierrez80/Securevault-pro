              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "threats": [
                {
                  "id": "threat-vault-authorization-gap",
                  "title": "Insufficient authorization enforcement",
                  "status": "Open",
                  "severity": "High",
                  "type": "Elevation of Privilege",
                  "description": "Token validation exists, but role-based authorization must remain enforced as the system evolves.",
                  "mitigation": "Keep route-level authorization dependencies and validate claims consistently.",
                  "modelType": "STRIDE"
                },
                {
                  "id": "threat-vault-rate-limit-bypass",
                  "title": "Abuse through rate-limit evasion",
                  "status": "Mitigated",
                  "severity": "Medium",
                  "type": "Denial of Service",
                  "description": "Attackers may attempt repeated requests against the vault API.",
                  "mitigation": "Redis-backed slowapi limiter is enabled for read and write endpoints.",
                  "modelType": "STRIDE"
                }
              ]
            }
