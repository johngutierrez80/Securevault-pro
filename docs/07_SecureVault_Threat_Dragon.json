              "threats": [
                {
                  "id": "threat-auth-hardcoded-secret",
                  "title": "Weak secret management",
                  "status": "Open",
                  "severity": "Critical",
                  "type": "Elevation of Privilege",
                  "description": "If default JWT signing secrets remain hardcoded, forged tokens become feasible after source disclosure.",
                  "mitigation": "Use protected environment variables or secret manager per environment.",
                  "modelType": "STRIDE"
                }
